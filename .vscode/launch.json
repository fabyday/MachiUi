{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MSVC Debug",
            "type": "cppvsdbg",
            "request": "launch", // 이 줄이 누락되면 해당 에러가 발생합니다.
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "CMake: build"
        },
    {
        "name": "macOS Debug",
    "type": "cppdbg",            // 맥/리눅스용 디버거 타입
    "request": "launch",
    "program": "${command:cmake.launchTargetPath}",
    "args": [],
    "stopAtEntry": false,
    "cwd": "${workspaceFolder}",
    "environment": [],
    "externalConsole": false,
    "MIMode": "lldb",            // 맥은 lldb를 사용합니다
    "setupCommands": [
        {
            "description": "Enable pretty-printing for gdb",
            "text": "-enable-pretty-printing",
            "ignoreFailures": true
        }
    ],
    "preLaunchTask": "CMake: build"
}
    ]
}